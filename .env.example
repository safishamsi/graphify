# depOS backend environment variables. Copy to .env and fill in before running
# `depos-api` or the intelligence CLI.

# --- Supabase / Postgres ---------------------------------------------------
# Postgres connection string. For local `supabase start` the default is:
#   postgres://postgres:postgres@127.0.0.1:54322/postgres
# For hosted Supabase, use the pooled or direct connection URL from the dashboard.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# Supabase project URL. Local: http://127.0.0.1:54321; Hosted: https://<ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Browser-facing Supabase URL for apps/web. Keep this aligned with SUPABASE_URL
# unless you intentionally need a different public value.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Anon (public) key. Safe to expose to the browser.
SUPABASE_ANON_KEY=replace-with-anon-key

# Browser-facing anon key for apps/web. Keep this aligned with SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Browser-facing depOS API base URL for apps/web. The Next app reads this from
# the repo-root .env and derives NEXT_PUBLIC_SUPABASE_* from SUPABASE_URL /
# SUPABASE_ANON_KEY automatically when not explicitly set.
NEXT_PUBLIC_DEPOS_API_URL=http://127.0.0.1:8080

# Service-role key. Server-only. Bypasses RLS. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# JWT verification. Local `supabase start` prints an HS256 secret; hosted
# projects use RS256 + JWKS (leave SUPABASE_JWT_SECRET unset in that case and
# set SUPABASE_JWT_ALG=RS256).
SUPABASE_JWT_ALG=HS256
SUPABASE_JWT_SECRET=replace-with-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated

# --- depOS -----------------------------------------------------------------
# Root directory for graph snapshots and intelligence run artifacts.
DEPOS_DATA=depos-data

# CORS origins for the FastAPI server (comma-separated).
DEPOS_CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Set to "production" to enforce strict startup checks (internal API key,
# explicit CORS, graph bucket). Leave unset for local dev.
# DEPOS_ENV=production

# Shared secret for worker/internal routes (/v1/snapshot, federation preview,
# drift with filesystem paths). When unset, those routes are open — do not
# expose the API publicly without setting this.
# DEPOS_INTERNAL_API_KEY=generate-a-long-random-secret

# Supabase Storage bucket for graph JSON (must exist after migrations).
DEPOS_GRAPH_BUCKET=graph-snapshots

# --- Intelligence layer (optional) -----------------------------------------
# Reasoning provider: gemma | openai | ollama. See depos.analysis.config.
DEPOS_INTEL_PROVIDER=gemma
# Provider keys (only the one matching DEPOS_INTEL_PROVIDER is read).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMMA_API_URL=http://127.0.0.1:8000
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Intent Context Layer (depos-intel intent-context build) ----------------
# When OPENAI_API_KEY is set, DEPOS_INTEL_INTENT_LLM=auto (default) also runs
# llm_v0 extraction plus file/repo summaries. Use "rules" for CI / no network.
# DEPOS_INTEL_INTENT_LLM=auto
# Optional model override for intent only (defaults to OPENAI_MODEL).
# DEPOS_INTEL_INTENT_MODEL=gpt-4o-mini
# DEPOS_INTEL_INTENT_MAX_TOKENS=4096
# DEPOS_INTEL_INTENT_MAX_REPO_BYTES=5000000
# DEPOS_INTEL_INTENT_MAX_CHUNKS=500
# DEPOS_INTEL_INTENT_MAX_FILE_BYTES=512000
# DEPOS_INTEL_INTENT_CHUNK_CHARS=8000
# DEPOS_INTEL_INTENT_CHUNK_OVERLAP=400
# DEPOS_INTEL_INTENT_FENCED=strip
# Scan source for OFT-style coverage tags ([impl->req~id~1]); set 0 to skip.
# DEPOS_INTEL_INTENT_TAG_SCAN=1
