# Legacy Next.js env example. Prefer putting these values in the repo-root .env;
# apps/web/next.config.js loads that file automatically.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# depOS API base URL (FastAPI). The browser calls this directly with the Supabase JWT.
NEXT_PUBLIC_DEPOS_API_URL=http://127.0.0.1:8080

# CORS: add this origin to the API (DEPOS_CORS_ORIGINS) so browser fetch succeeds, e.g.
#   DEPOS_CORS_ORIGINS=http://localhost:3001
# Production: list your real web origins (comma-separated), never leave * in production.
